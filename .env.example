# Ollama connection
OLLAMA_BASE_URL=http://localhost:11434
# Leave blank if no auth required
OLLAMA_AUTH_HEADER=
OLLAMA_AUTH_VALUE=

# OpenClaw Gateway (Phase 3)
# Default: SSH tunnel to OpenClaw host (ssh -N -L 18789:127.0.0.1:18789 user@host)
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=
# Optional HTTP endpoint for debug/prototype only
OPENCLAW_HTTP_BASE_URL=http://127.0.0.1:18789

# Telegram bot (allowed Telegram user IDs are configured in config.yml -> telegram.allowed_user_ids)
TELEGRAM_BOT_TOKEN=

# Backend API token (used by SSR frontend when calling backend APIs)
BACKEND_API_TOKEN=

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=seedwake
DB_USER=seedwake
DB_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
