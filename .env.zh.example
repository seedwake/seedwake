# Seedwake 环境变量
# 复制为 .env，并根据部署方式按需填写。
#
# 约定：
#   [必填]              必须填写
#   [条件必填：...]      满足条件时必须填写
#   [可选]              可以留空；会走默认值或优雅降级

# ============================================================================
# Ollama
# ============================================================================
# [条件必填] 当 config.yml 里任一模型（primary / auxiliary / embedding）的
#            provider 为 "ollama" 时必填。如果 Ollama 跟 core 跑在同一台宿主机
#            上，保留默认值即可。
OLLAMA_BASE_URL=http://localhost:11434

# [可选] 自定义 auth header 的名字和值。普通无鉴权的 Ollama 两项都留空。
#        只有当 Ollama 放在反向代理后、代理要求自定义 header 时才需要填写。
OLLAMA_AUTH_HEADER=
OLLAMA_AUTH_VALUE=

# ============================================================================
# OpenClaw Gateway
# ============================================================================
# [条件必填] 当 config.yml 的 actions.auto_execute 或 actions.require_confirmation
#            里包含任何非原生动作（search / web_fetch / reading / weather /
#            file_modify / system_change），或任一模型的 provider 为 "openclaw"
#            时必填。
#
# 默认假设通过 SSH 隧道转发到本地，例如：
#     ssh -N -L 18789:127.0.0.1:18789 user@openclaw-host
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789

# [条件必填] 使用 WS Gateway 时必填。从 OpenClaw 侧获取。
OPENCLAW_GATEWAY_TOKEN=

# [条件必填] 启用 WS fallback（actions.use_openclaw_http_fallback: true），
#            或 primary / auxiliary 模型的 provider 为 "openclaw" 时必填。
#            只用 WS 的场景可留空。
OPENCLAW_HTTP_BASE_URL=http://127.0.0.1:18789

# ============================================================================
# 通用 OpenAI 兼容端点
# ============================================================================
# [条件必填] 当 config.yml 里任一模型的 provider 为 "openai_compatible" 时
#            必填。否则留空。
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=

# [可选] 为期望 x-openclaw-scopes 头的 gateway 提供的额外 scope 头。
#        普通 OpenAI 兼容端点留空即可。
OPENAI_COMPAT_SCOPES=

# ============================================================================
# Telegram Bot
# ============================================================================
# [条件必填] 启动 bot 容器（docker compose up -d bot）时必填。
#            Token 从 @BotFather 获取。
#            允许和 Seedwake 私聊的 Telegram user id 列表在
#            config.yml -> telegram.allowed_user_ids 里配置，不在这里配。
TELEGRAM_BOT_TOKEN=

# ============================================================================
# Backend API
# ============================================================================
# [条件必填] 启动 backend 容器（docker compose up -d backend）时必填。
#            作为 backend 与 SSR 前端之间的共享 secret。暂时不跑 backend
#            可留空。
BACKEND_API_TOKEN=

# ============================================================================
# PostgreSQL（长期记忆）
# ============================================================================
# [必填] 四项都要填。如果用 docker compose up -d postgresql，
#        容器会从这里读取 DB_NAME / DB_USER / DB_PASSWORD 做首次初始化。
DB_HOST=localhost
DB_PORT=5432
DB_NAME=seedwake
DB_USER=seedwake
DB_PASSWORD=

# ============================================================================
# Redis（短期记忆、事件总线、动作状态）
# ============================================================================
# [必填] 必须与 compose 暴露的端口一致。用项目自带的 docker-compose.yml
#        时默认值即可。
REDIS_HOST=localhost
REDIS_PORT=6379
