# Backend base URL (server-side only — not exposed to browser)
NUXT_BACKEND_BASE_URL=http://127.0.0.1:8000

# Backend API token (server-side only — injected as X-API-Token)
NUXT_BACKEND_API_TOKEN=your-api-token-here

# UI language. Must match the `language:` field in config.yml for
# SSE status/action messages to render in the matching locale.
# zh | en
NUXT_PUBLIC_LANGUAGE=zh

# Static demo mode. When true, the frontend uses local mock events and does not
# connect to backend /api/stream.
NUXT_PUBLIC_DEMO=false
