# Seedwake environment variables
# Copy to .env and fill in the values according to your deployment.
#
# Convention:
#   [REQUIRED]            must always be filled
#   [REQUIRED IF ...]     must be filled when the stated condition holds
#   [OPTIONAL]            can be left blank; a default or a graceful fallback applies

# ============================================================================
# Ollama
# ============================================================================
# [REQUIRED IF] any model (primary / auxiliary / embedding) in config.yml uses
#               provider: "ollama". Leave the default if Ollama runs on the
#               same host as core.
OLLAMA_BASE_URL=http://localhost:11434

# [OPTIONAL] Custom auth header name + value. Leave both blank for a plain
#            Ollama instance with no auth. Set them only if your Ollama is
#            behind a reverse proxy that expects a custom header.
OLLAMA_AUTH_HEADER=
OLLAMA_AUTH_VALUE=

# ============================================================================
# OpenClaw Gateway
# ============================================================================
# [REQUIRED IF] any non-native action (search / web_fetch / reading / weather /
#               file_modify / system_change) is listed in actions.auto_execute
#               or actions.require_confirmation, OR any model in config.yml
#               uses provider: "openclaw".
#
# Default assumes OpenClaw is reached through an SSH tunnel to the host that
# runs it, e.g.:
#     ssh -N -L 18789:127.0.0.1:18789 user@openclaw-host
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789

# [REQUIRED IF] the WS Gateway is used. Obtained from your OpenClaw instance.
OPENCLAW_GATEWAY_TOKEN=

# [REQUIRED IF] WS fallback is enabled (actions.use_openclaw_http_fallback:
#               true) or the primary / auxiliary model uses
#               provider: "openclaw". Leave blank if you only use WS.
OPENCLAW_HTTP_BASE_URL=http://127.0.0.1:18789

# ============================================================================
# Generic OpenAI-compatible endpoint
# ============================================================================
# [REQUIRED IF] any model in config.yml uses provider: "openai_compatible".
#               Leave blank otherwise.
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=

# [OPTIONAL] Extra scopes header for gateways that expect x-openclaw-scopes.
#            Leave blank for plain OpenAI-compatible endpoints.
OPENAI_COMPAT_SCOPES=

# ============================================================================
# Telegram bot
# ============================================================================
# [REQUIRED IF] you start the bot container (docker compose up -d bot).
#               Token from @BotFather.
#               The list of allowed Telegram user IDs is configured in
#               config.yml -> telegram.allowed_user_ids, not here.
TELEGRAM_BOT_TOKEN=

# ============================================================================
# Backend API
# ============================================================================
# [REQUIRED IF] you start the backend container (docker compose up -d backend).
#               Used as a shared secret between backend and the SSR frontend.
#               Leave blank if you don't run backend yet.
BACKEND_API_TOKEN=

# ============================================================================
# PostgreSQL (used by long-term memory)
# ============================================================================
# [REQUIRED] all four values must be filled. If you use docker compose up -d
#            postgresql, the container reads DB_NAME / DB_USER / DB_PASSWORD
#            from here to initialize itself.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=seedwake
DB_USER=seedwake
DB_PASSWORD=

# ============================================================================
# Redis (used for short-term memory, event bus, action state)
# ============================================================================
# [REQUIRED] must match what compose exposes. Default values work out of the
#            box with the provided docker-compose.yml.
REDIS_HOST=localhost
REDIS_PORT=6379
